# SMPP Server Configuration
# Usage: cp .env.example .env  then fill in your values

SMPP_LISTEN=YOUR_SERVER_IP:2775
HTTP_LISTEN=YOUR_SERVER_IP:8080

IP_WHITELIST_FILE=./whitelist.txt

NGS_BASE_URL=https://sg.nextgenswitch.com
NGS_AUTH_CODE=YOUR_NGS_AUTH_CODE
NGS_AUTH_SECRET=YOUR_NGS_AUTH_SECRET
NGS_TIMEOUT=8
# statusCallback and /ngs/status path are auto-derived from HTTP_LISTEN

DB_PATH=./smpp.db
# CSV_LOG=./smpp.csv   # uncomment to enable CSV logging
LOG_LEVEL=INFO
DLR_INTERMEDIATE=false

# Play mode: inline = <Say> in responseXml (charges on every attempt)
#            redirect = <Redirect> to /play/<token> (charges only on answered calls)
#            play URL is auto-derived from HTTP_LISTEN
PLAY_MODE=inline

# Billing web admin
WEB_HOST=0.0.0.0
WEB_PORT=8888
WEB_PASSWORD=CHANGE_ME
WEB_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
